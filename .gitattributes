# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Explicitly LF for source and config files.
*.go      text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.service text eol=lf

# Binary files: never touch line endings.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.exe binary
